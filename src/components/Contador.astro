---
// Contador.astro  (Fecha del evento)
---

<div
    id="fecha-contenedor"
    data-entrada
    class="relative w-full flex flex-col items-center justify-center text-center px-6 py-12"
>
    <!-- FRASE -->
    <p
        id="fecha-frase"
        class="m-0 font-great-vibes text-[#5a6a32] text-[30px] leading-[1.3] max-w-[300px]"
    >
        Me gustaría que seas parte de este día especial
    </p>

    <!-- CORAZÓN -->
    <svg
        id="fecha-corazon"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        class="w-[22px] h-auto my-6 text-[#5a6a32]"
        fill="currentColor"
    >
        <path
            d="M12 21s-7.5-5-9.7-9.3C.9 8.4 2.7 4.5 6.3 4.5c2 0 3.3 1.2 4.2 2.4C11.4 5.7 12.7 4.5 14.7 4.5c3.6 0 5.4 3.9 4 7.2C16.5 16 12 21 12 21z"
        ></path>
    </svg>

    <!-- CORONA -->
    <img
        src="/imagenes/corona.png"
        alt="Corona"
        id="fecha-corona"
        class="w-[80px] h-auto pointer-events-none select-none"
    />

    <!-- BLOQUE DE FECHA -->
    <div
        id="fecha-bloque"
        class="relative w-full max-w-[320px] mx-auto mt-3 flex items-center justify-center"
    >
        <div class="relative z-10 flex items-center justify-center w-full">
            <!-- DÍA DE LA SEMANA -->
            <div class="flex-1 flex flex-col items-center gap-2">
                <span class="w-16 h-px bg-[#5a6a32]/60"></span>
                <span
                    class="font-crimson uppercase text-[#5a6a32] text-[17px] tracking-[0.12em]"
                >
                    Sábado
                </span>
                <span class="w-16 h-px bg-[#5a6a32]/60"></span>
            </div>

            <!-- CÁPSULA CON EL DÍA -->
            <div
                class="relative flex items-center justify-center w-[86px] h-[132px] shrink-0
                       rounded-full border-2 border-[#5a6a32] bg-white/55 backdrop-blur-sm"
            >
                <!-- ciudad (arriba) -->
                <span
                    class="absolute top-4 left-0 right-0 font-crimson uppercase text-[#5a6a32] text-[9px] tracking-[0.18em]"
                >
                    Tiquipaya
                </span>

                <!-- día centrado -->
                <span
                    class="font-crimson font-bold text-[#5a6a32] text-[46px] leading-none"
                >
                    25
                </span>

                <!-- año (abajo) -->
                <span
                    class="absolute bottom-4 left-0 right-0 font-crimson text-[#5a6a32] text-[15px] opacity-80"
                >
                    2026
                </span>
            </div>

            <!-- MES -->
            <div class="flex-1 flex flex-col items-center gap-2">
                <span class="w-16 h-px bg-[#5a6a32]/60"></span>
                <span
                    class="font-crimson uppercase text-[#5a6a32] text-[17px] tracking-[0.12em]"
                >
                    Julio
                </span>
                <span class="w-16 h-px bg-[#5a6a32]/60"></span>
            </div>
        </div>
    </div>
</div>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    function setupFecha() {
        const contenedor = document.getElementById("fecha-contenedor");
        if (!contenedor) return;

        gsap.from(
            [
                "#fecha-frase",
                "#fecha-corazon",
                "#fecha-corona",
                "#fecha-bloque",
            ],
            {
                opacity: 0,
                y: 25,
                duration: 1,
                ease: "power3.out",
                stagger: 0.15,
                scrollTrigger: {
                    trigger: contenedor,
                    start: "top 85%",
                    toggleActions: "play none none reset",
                },
            },
        );
    }

    document.addEventListener("DOMContentLoaded", setupFecha);
    document.addEventListener("astro:page-load", setupFecha);
</script>
