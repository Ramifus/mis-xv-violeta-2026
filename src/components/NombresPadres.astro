---
// NombresPadres.astro
---

<div
    id="padres-contenedor"
    data-entrada
    class="relative w-full flex flex-col items-center justify-center text-center px-6 py-8"
>
    <!-- CORAZÓN PRINCIPAL + CORAZONES VOLANDO -->
    <div
        id="padres-corazones"
        class="relative w-[150px] h-[110px] mb-5 flex items-center justify-center"
    >
        <!-- corazones pequeños alrededor (SVG para que sean verdes) -->
        <svg class="corazon-vuela absolute text-[#5a6a32]" style="left:6%; top:20%; width:13px;" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21s-7.5-5-9.7-9.3C.9 8.4 2.7 4.5 6.3 4.5c2 0 3.3 1.2 4.2 2.4C11.4 5.7 12.7 4.5 14.7 4.5c3.6 0 5.4 3.9 4 7.2C16.5 16 12 21 12 21z"/></svg>
        <svg class="corazon-vuela absolute text-[#5a6a32]" style="left:14%; top:60%; width:9px;" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21s-7.5-5-9.7-9.3C.9 8.4 2.7 4.5 6.3 4.5c2 0 3.3 1.2 4.2 2.4C11.4 5.7 12.7 4.5 14.7 4.5c3.6 0 5.4 3.9 4 7.2C16.5 16 12 21 12 21z"/></svg>
        <svg class="corazon-vuela absolute text-[#5a6a32]" style="right:8%; top:14%; width:14px;" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21s-7.5-5-9.7-9.3C.9 8.4 2.7 4.5 6.3 4.5c2 0 3.3 1.2 4.2 2.4C11.4 5.7 12.7 4.5 14.7 4.5c3.6 0 5.4 3.9 4 7.2C16.5 16 12 21 12 21z"/></svg>
        <svg class="corazon-vuela absolute text-[#5a6a32]" style="right:12%; top:58%; width:10px;" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21s-7.5-5-9.7-9.3C.9 8.4 2.7 4.5 6.3 4.5c2 0 3.3 1.2 4.2 2.4C11.4 5.7 12.7 4.5 14.7 4.5c3.6 0 5.4 3.9 4 7.2C16.5 16 12 21 12 21z"/></svg>
        <svg class="corazon-vuela absolute text-[#5a6a32]" style="left:38%; top:2%; width:8px;" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21s-7.5-5-9.7-9.3C.9 8.4 2.7 4.5 6.3 4.5c2 0 3.3 1.2 4.2 2.4C11.4 5.7 12.7 4.5 14.7 4.5c3.6 0 5.4 3.9 4 7.2C16.5 16 12 21 12 21z"/></svg>
        <svg class="corazon-vuela absolute text-[#5a6a32]" style="right:32%; bottom:2%; width:12px;" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21s-7.5-5-9.7-9.3C.9 8.4 2.7 4.5 6.3 4.5c2 0 3.3 1.2 4.2 2.4C11.4 5.7 12.7 4.5 14.7 4.5c3.6 0 5.4 3.9 4 7.2C16.5 16 12 21 12 21z"/></svg>

        <!-- corazón principal (doble) -->
        <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 64 40"
            class="relative w-[64px] h-auto text-[#5a6a32]"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
        >
            <path
                d="M20 34C20 34 6 26 6 15.5C6 10 10 6 15 6C18 6 20 8 20 8C20 8 22 6 25 6C30 6 34 10 34 15.5C34 26 20 34 20 34Z"
            ></path>
            <path
                d="M42 34C42 34 30 27 30 17.5C30 12.5 33.5 9 38 9C40.5 9 42 10.5 42 10.5C42 10.5 43.5 9 46 9C50.5 9 54 12.5 54 17.5C54 27 42 34 42 34Z"
            ></path>
        </svg>
    </div>

    <!-- TÍTULO -->
    <p
        id="padres-titulo"
        class="m-0 font-great-vibes text-[#5a6a32] text-[30px] leading-none"
    >
        Gracias al apoyo de mis Padres
    </p>

    <!-- NOMBRES (una sola línea) -->
    <p
        id="padres-nombres"
        class="m-0 mt-5 font-crimson font-bold text-[#bfd67e] text-[32px] leading-tight tracking-[0.02em]"
    >
        Jheimy &amp; Ariel
    </p>
</div>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    function setupPadres() {
        const contenedor = document.getElementById("padres-contenedor");
        if (!contenedor) return;

        // Entrada al hacer scroll
        gsap.from(
            ["#padres-corazones", "#padres-titulo", "#padres-nombres"],
            {
                opacity: 0,
                y: 25,
                duration: 1,
                ease: "power3.out",
                stagger: 0.15,
                scrollTrigger: {
                    trigger: contenedor,
                    start: "top 85%",
                    toggleActions: "play none none reset",
                },
            },
        );

        // Corazones voladores: flotan y titilan
        gsap.utils.toArray<HTMLElement>(".corazon-vuela").forEach((h, i) => {
            const dur = 1.8 + Math.random() * 1.4;
            gsap.to(h, {
                y: "-=10",
                x: `+=${Math.random() * 8 - 4}`,
                duration: dur,
                ease: "sine.inOut",
                repeat: -1,
                yoyo: true,
                delay: i * 0.25,
            });
            gsap.to(h, {
                opacity: 0.25,
                duration: dur * 0.8,
                ease: "sine.inOut",
                repeat: -1,
                yoyo: true,
                delay: i * 0.3,
            });
        });
    }

    document.addEventListener("DOMContentLoaded", setupPadres);
    document.addEventListener("astro:page-load", setupPadres);
</script>
